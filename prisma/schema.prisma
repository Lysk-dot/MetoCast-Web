generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Comment {
  id        Int      @id @default(autoincrement())
  videoId   String   @map("video_id")
  author    String   @db.VarChar(100)
  message   String   @db.VarChar(2000)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([videoId])
  @@map("comments")
}

model Suggestion {
  id          Int      @id @default(autoincrement())
  author      String   @db.VarChar(100)
  title       String   @db.VarChar(200)
  description String   @db.VarChar(2000)
  votes       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("suggestions")
}

model PageView {
  id        Int      @id @default(autoincrement())
  path      String   @db.VarChar(500)
  sessionId String   @map("session_id") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([path])
  @@index([createdAt])
  @@map("page_views")
}

model VideoView {
  id           Int      @id @default(autoincrement())
  videoId      String   @map("video_id") @db.VarChar(20)
  sessionId    String   @map("session_id") @db.VarChar(100)
  watchSeconds Int      @default(0) @map("watch_seconds")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([videoId])
  @@index([createdAt])
  @@map("video_views")
}

model Participacao {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(200)
  cargo     String?  @db.VarChar(300)
  episodio  String?  @db.VarChar(300)
  videoId   String?  @map("video_id") @db.VarChar(20)
  data      String?  @db.VarChar(10)
  fotoUrl   String?  @map("foto_url") @db.VarChar(1000)
  videoUrl  String?  @map("video_url") @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("participacoes")
}
