# ============================
# MetôCast - Variáveis para Docker
# ============================
# Copie este arquivo para .env e preencha os valores reais

# Senha do banco PostgreSQL
DB_PASSWORD=metocast_password_segura_aqui

# URL pública do site (usada em metadados SEO)
SITE_URL=https://metocast.example.com

# Token do Cloudflare Tunnel
# Obtenha em: https://one.dash.cloudflare.com → Zero Trust → Network → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=seu_token_aqui
